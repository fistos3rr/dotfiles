# vim:ft=kitty

## name:     E-Ink Dark
## author:   Algilbert Gomez (https://github.com/alexxGmZ)
## license:  MIT
## upstream: https://github.com/alexxGmZ/e-ink.kitty/blob/main/E-Ink-Dark.conf
## blurb:    A grayscale theme aiming to imitate e-ink displays.

background_image /home/x4nyx/Downloads/test.jpg
background_image_layout scaled
background_image_linear yes
background_tint 0.9
background_tint_gaps 1.0

# BEGIN_KITTY_FONTS
font_family      family="Fira Code"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS
font_size        12.0

foreground #C2C2C2
background #333333
selection_foreground none
selection_background #545454

cursor none

# black
color0  #333333
color8  #A4A4A4

# red
color1  #CCCCCC
color9  #CCCCCC

# green
color2  #686868
color10 #686868

# yellow
color3  #7C7C7C
color11 #7C7C7C

# blue
color4  #868686
color12 #868686

# magenta
color5  #5E5E5E
color13 #5E5E5E

# cyan
color6  #B8B8B8
color14 #B8B8B8

# black
color7  #A4A4A4
color15 #868686

# START_AUTOGENERATED_TAB_STYLE
# Feel free to update these colors manually and remove these comments.
active_tab_foreground   #eeeeee
active_tab_background   #545454
inactive_tab_foreground #C2C2C2
inactive_tab_background #292929
# END_AUTOGENERATED_TAB_STYLE
